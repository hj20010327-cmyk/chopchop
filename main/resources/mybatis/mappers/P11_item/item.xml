<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="mapper.P11_item">

	<select id="selectItemCount"
		parameterType="kr.or.chop.P11_item.dto.ItemDTO" resultType="int">

		select count(*)
		from item
		where item_usage = 'Y'	
		
	</select>
	
	<select id="selectitemList"
		parameterType="kr.or.chop.P11_item.dto.ItemDTO" resultType="map">
	
		select * from item	
		
	</select>

</mapper>




